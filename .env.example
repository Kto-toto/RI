# ─────────────────────────────────────────────────────────
#  Regulatory Intelligence — конфигурация
#  Скопируйте этот файл → переименуйте в .env → заполните
# ─────────────────────────────────────────────────────────

# ── Мониторинг ────────────────────────────────────────────
# Интервал проверки RSS (в секундах). По умолчанию 300 = 5 минут
CHECK_INTERVAL=300

# ── LLM для суммаризации пояснительных записок ────────────
# Провайдер: claude / perplexity / deepseek
# Оставьте пустым если не нужна суммаризация
LLM_PROVIDER=

# Claude (Anthropic)
# Ключ: https://console.anthropic.com/
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# Perplexity
# Ключ: https://docs.perplexity.ai/
PPLX_API_KEY=
PPLX_MODEL=sonar-pro

# DeepSeek
# Ключ: https://platform.deepseek.com/
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# ── Confluence Cloud ──────────────────────────────────────
# Оставьте пустыми если синхронизация не нужна

# URL вашего Confluence (без / в конце)
CONFLUENCE_URL=

# Email Atlassian-аккаунта
CONFLUENCE_EMAIL=

# API-токен: https://id.atlassian.com/manage-api-tokens
CONFLUENCE_TOKEN=

# Ключ пространства (Space Key из URL: .../spaces/RI/...)
CONFLUENCE_SPACE=

# ID родительской страницы (необязательно)
CONFLUENCE_PARENT_ID=
